# Azure dbt MCP Agent - Environment Variables

# ─── LLM (Choose one) ───

# Option 1: Azure AI Foundry (Recommended - supports GPT, Llama, Phi, Cohere, etc.)
AZURE_AI_FOUNDRY_ENDPOINT=https://your-project.services.ai.azure.com/
AZURE_AI_FOUNDRY_KEY=your-foundry-api-key
AZURE_AI_FOUNDRY_MODEL=gpt-4o

# Option 2: Azure OpenAI (Classic deployment)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your-azure-openai-key
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Option 3: Direct OpenAI (Fallback)
# OPENAI_API_KEY=your-openai-key

# ─── Azure PostgreSQL (Chat History) ───
AZURE_PG_CONNECTION_STRING=postgresql://user:password@your-server.postgres.database.azure.com:5432/dbt_agent?sslmode=require

# ─── Azure AI Content Safety ───
CONTENT_SAFETY_ENDPOINT=https://your-content-safety.cognitiveservices.azure.com/
CONTENT_SAFETY_KEY=your-content-safety-key

# ─── dbt Configuration ───
DBT_PROJECT_DIR=./local_dbt_test
DBT_PROFILES_DIR=./local_dbt_test

# ─── Logging ───
LOG_LEVEL=INFO
